# rustc internal compiler-error reports — sometimes generated under
# heavy concurrent build pressure during parallel agent dispatch.
rustc-ice-*.txt

# Lockfiles generated by `locus init` test runs against sample-crate fixtures.
tests/fixtures/sample-crate/locus.lock

# Cargo.lock generated when the rustdoc-JSON backend builds the
# semantic-conversions fixture during integration tests. The fixture
# is a `[workspace]`-severed library crate with no external deps;
# checking in its lockfile would only add churn between cargo
# versions. Matches the convention used by tests/fixtures/markers-crate.
tests/fixtures/semantic-conversions-fixture/Cargo.lock

# Cargo build output. With the project-local .cargo/config.toml setting
# `target-dir = "target"`, builds land under each worktree's root.
target/
