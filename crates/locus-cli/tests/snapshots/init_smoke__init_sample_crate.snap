[feature] no features defined; DG/FO will not fire
  top-level modules: dto, handler, identity, shadow
  empty public_api means the feature surface is not yet declared, not that every cross-feature import is an architecture bug — DG003 only flags reaches into internals once features list a public_api
  define:
    locus dg define-feature --name dto --module "dto::*" --public-api "dto::*"
    locus dg define-feature --name handler --module "handler::*" --public-api "handler::*"
    locus dg define-feature --name identity --module "identity::*" --public-api "identity::*"
    locus dg define-feature --name shadow --module "shadow::*" --public-api "shadow::*"
    # (FO mirrors DG features once these are accepted)
  or skip:
    locus init --acknowledge-empty DG,FO

[threshold] CX001 function-line p95 = 7; default = 50
  p95 differs from default by >1.5×; consider explicit cap
  set explicit cap:
    locus cx set-default --max-lines 8

